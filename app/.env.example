# API key must be scoped to your project.
# A project-scoped key automatically filters all API responses to that project.
# Do NOT use an organization-level key.
REECALL_API_KEY=your_project_scoped_api_key_here
REECALL_BASE_URL=https://newprd.reecall.io/data_next
REECALL_CALLS_URL=https://newprd.reecall.io/calls

# Twilio (for SIP transfer)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok.io # or other public address
