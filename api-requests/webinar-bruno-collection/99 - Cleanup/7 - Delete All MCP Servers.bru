meta {
  name: Delete All MCP Servers
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/ai/MCP/?where={"projectId":"{{projectId}}"}
  body: none
  auth: inherit
}

script:post-response {
  const items = res.body;
  if (items && items.length) {
    for (const item of items) {
      await axios.delete(`${bru.getEnvVar("baseUrl")}/ai/MCP/${item.id}`, {
        headers: { Authorization: `Bearer ${bru.getEnvVar("apiKey")}` }
      });
    }
  }
}
