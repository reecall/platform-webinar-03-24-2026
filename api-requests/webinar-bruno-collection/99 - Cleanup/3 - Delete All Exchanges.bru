meta {
  name: Delete All Exchanges
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/conversational/exchanges/?where={"projectId":"{{projectId}}"}
  body: none
  auth: inherit
}

script:post-response {
  const items = res.body;
  if (items && items.length) {
    for (const item of items) {
      await axios.delete(`${bru.getEnvVar("baseUrl")}/conversational/exchanges/${item.id}`, {
        headers: { Authorization: `Bearer ${bru.getEnvVar("apiKey")}` }
      });
    }
  }
}
