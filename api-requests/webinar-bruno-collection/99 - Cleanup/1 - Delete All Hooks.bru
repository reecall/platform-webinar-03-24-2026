meta {
  name: Delete All Hooks
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/automation/hooks/?where={"projectId":"{{projectId}}"}
  body: none
  auth: inherit
}

script:post-response {
  const items = res.body;
  if (items && items.length) {
    for (const item of items) {
      await axios.delete(`${bru.getEnvVar("baseUrl")}/automation/hooks/${item.id}`, {
        headers: { Authorization: `Bearer ${bru.getEnvVar("apiKey")}` }
      });
    }
  }
}
